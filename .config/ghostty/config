# Ghostty config — matched to kitty + wezterm setups
# Source of truth: ~/.config/wezterm/wezterm.lua and ~/.config/kitty/kitty.conf

# Font
font-family = Monoid
font-size = 12
# kitty adjust_line_height 130% / wezterm line_height 1.3
adjust-cell-height = 30%

# Color scheme
theme = Breeze
#theme = Tomorrow Night

# Cursor: blinking bar (wezterm BlinkingBar)
cursor-style = bar
cursor-style-blink = true

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true
macos-titlebar-style = hidden

# Copy on select (kitty copy_on_select yes)
copy-on-select = true

# Bell off (kitty/wezterm both disabled)
# ghostty has no audible bell; nothing to disable

# macOS: left option = alt, right option = native (matches kitty/wezterm)
macos-option-as-alt = left

# Fullscreen toggle ctrl+cmd+f (matches wezterm)
keybind = ctrl+cmd+f=toggle_fullscreen

# Guake-style drop-down quick terminal (ctrl+` toggles, works app-unfocused)
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.1
quick-terminal-size = 80%

# Transparency (85% opaque / 15% see-through)
background-opacity = 0.85
background-blur = true
